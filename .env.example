# The Secretary Swarm - Environment Configuration Template
# Salin file ini menjadi .env dan isi dengan kunci yang valid.

# --- Telegram Bot ---
# Dapatkan dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Google Gemini AI ---
# Dapatkan dari https://aistudio.google.com/
GOOGLE_API_KEY=your_google_gemini_api_key_here

# --- Supabase Database ---
# Dapatkan dari Dashboard Project Supabase -> Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
